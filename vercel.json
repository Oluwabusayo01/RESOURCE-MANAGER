{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/index.js"
    },
    {
      "source": "/:path(.*\\.[a-zA-Z0-9]+)",
      "destination": "client/:path"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "client/index.html"
    }
  ]
}
