{
  "version": 2,
  "cleanUrls": true,
  "services": {
    "client": {
      "root": "client"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "index.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend"
    },
    {
      "source": "/(.*)",
      "destination": "client/dist/$1"
    }
  ]
}
