{
  "version": 2,
  "services": {
    "frontend": {
      "root": "client"
    },
    "backend": {
      "root": "backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend"
    },
    {
      "source": "/:path*",
      "destination": "client"
    }
  ]
}
